-- profile
CREATE TABLE profile (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  name TEXT NOT NULL,
  title TEXT NOT NULL,
  location TEXT,
  bio TEXT,
  sub_text TEXT,
  description TEXT,
  city TEXT,
  cv_url TEXT,
  github_url TEXT,
  linkedin_url TEXT,
  email_address TEXT,
  profile_image TEXT,
  gpa TEXT,
  university TEXT
);
INSERT INTO profile VALUES (1,'CHOA LEE','Information Management','Canada','Passionate junior software engineer with a growing foundation in cloud infrastructure (AWS) and web development. Eager to build scalable, secure, and automated systems.','Building efficient workflows that turn complex data into actionable automation.','I graduated in &lt;b class=&quot;theme-accent&quot;&gt;Information Management&lt;/b&gt;, focusing on systems, data, and digital processes. Through academic and practical projects, I gained experience in structuring workflows and automating repetitive tasks using tools like n8n and Google Workspace, improving both efficiency and data clarity. &lt;br&gt;&amp;nbsp;&amp;nbsp;I am also building foundational knowledge in cloud infrastructure and cybersecurity, including AWS Certified Cloud Practitioner training. This complements my workflow experience, preparing me for IT operations roles and future growth into cloud- and security-focused domains. &lt;br&gt;&amp;nbsp;&amp;nbsp;I am ready to relocate to Vancouver, Canada in March 2026, aiming to contribute to IT operations while developing skills that bridge workflow automation and cloud security. My goal is to design clear, manageable systems that scale effectively and support long-term organizational growth.','Vancouver','https://drive.google.com/file/d/1j9bazhW2dDGcVAmnCMMm9tPS59AUwO7j/view?https://drive.google.com/uc?export=download&amp;id=1j9bazhW2dDGcVAmnCMMm9tPS59AUwO7j',NULL,'www.linkedin.com/in/','lee.choa.a@gmail.com','https://lh3.googleusercontent.com/u/0/d/1YFQJ2zSdh6QqmhpBHH84WxL6zhLKXbmv','3.44 / 4.3 (A-)','Chung Yuan Christian University');

-- projects
CREATE TABLE projects (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  title TEXT NOT NULL,
  tech_stack TEXT,
  description TEXT,
  image_url TEXT,
  project_url TEXT,
  member_type TEXT,
  is_visible INTEGER DEFAULT 0
);
INSERT INTO projects VALUES (1,'Senior Healthcare App','Firebase, n8n, MongoDB','AI-driven healthcare system featuring wearable data syncing, emotion tracking, and medication alerts.','https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&amp;fit=crop&amp;q=80&amp;w=1000','https://github.com/HaopingLi/healthcare-app','TEAM',1);
INSERT INTO projects VALUES (2,'Automation Workflow','n8n, Python, API','Business process automation connecting LINE Bots and Google Sheets to streamline repetitive tasks.','https://images.unsplash.com/photo-1576091160550-2173dba999ef?auto=format&amp;fit=crop&amp;q=80&amp;w=1000','','TEAM',1);
INSERT INTO projects VALUES (3,'Data Analysis Dash','Python, Power BI, MySQL','E-commerce and user behavior data visualization with optimized SQL queries and predictive modeling.','auto=format&amp;fit=crop&amp;q=80&amp;w=1000','','ALONE',0);
INSERT INTO projects VALUES (4,'Web Security Audit','OWASP Top 10, SQLi, XSS','Comprehensive security audit of web applications, testing for SQL injection and cross-site scripting.','auto=format&amp;fit=crop&amp;q=80&amp;w=1000','','ALONE',0);
INSERT INTO projects VALUES (5,'AWS Cloud Deployment','AWS S3, EC2, RDS','Scalable cloud infrastructure setup featuring static site hosting and secure database integration.','auto=format&amp;fit=crop&amp;q=80&amp;w=1000','','ALONE',0);

-- reference
CREATE TABLE reference (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  experience_id INTEGER NOT NULL,
  name TEXT NOT NULL,
  title TEXT NOT NULL,
  organization TEXT NOT NULL,
  email TEXT,
  linkedin_url TEXT,
  relationship TEXT,
  content TEXT NOT NULL,
  image_url TEXT,
  is_visible INTEGER DEFAULT 1,
  FOREIGN KEY (experience_id) REFERENCES experience (id) ON DELETE CASCADE
);
INSERT INTO reference VALUES (1,2,'Liam Robinson','Senior Engineer','Lam Research Manufacturing','liam.robinson@lamresearch.com','https://www.linkedin.com/in/liam-robinson','Supervisor','Choa demonstrates exceptional analytical skills in hardware testing. A highly reliable team member.',NULL,1);

