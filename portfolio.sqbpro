<?xml version="1.0" encoding="UTF-8"?><sqlb_project><db path="portfolio.db" readonly="0" foreign_keys="1" case_sensitive_like="0" temp_store="0" wal_autocheckpoint="1000" synchronous="2"/><attached/><window><main_tabs open="structure browser pragmas query" current="3"/></window><tab_structure><column_width id="0" width="300"/><column_width id="1" width="0"/><column_width id="2" width="100"/><column_width id="3" width="2100"/><column_width id="4" width="0"/><expanded_item id="0" parent="1"/><expanded_item id="1" parent="1"/><expanded_item id="2" parent="1"/><expanded_item id="3" parent="1"/></tab_structure><tab_browse><table title="about_features" custom_title="0" dock_id="2" table="4,14:mainabout_features"/><dock_state state="000000ff00000000fd00000001000000020000000000000000fc0100000002fb000000160064006f0063006b00420072006f00770073006500310100000000ffffffff0000000000000000fb000000160064006f0063006b00420072006f00770073006500320100000000ffffffff0000010e00ffffff000000000000000000000004000000040000000800000008fc00000000"/><default_encoding codec=""/><browse_table_settings/></tab_browse><tab_sql><sql name="SQL 1*">-- 1. 기존 테이블 삭제 (초기화용)
DROP TABLE IF EXISTS about_features;
DROP TABLE IF EXISTS certificates;
DROP TABLE IF EXISTS core_strenghts;
DROP TABLE IF EXISTS coursework;
DROP TABLE IF EXISTS experience;
DROP TABLE IF EXISTS languages;
DROP TABLE IF EXISTS profile;
DROP TABLE IF EXISTS projects;
DROP TABLE IF EXISTS reference;
DROP TABLE IF EXISTS skills;

-- 2. 테이블 생성 및 데이터 삽입

-- about_features
CREATE TABLE about_features (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  icon TEXT,
  title TEXT,
  content TEXT
);
INSERT INTO about_features VALUES (1,'fa-graduation-cap','Academic Foundation','Graduated in Information Management with a focus on systems, data, and digital processes.');
INSERT INTO about_features VALUES (2,'fa-cloud','Cloud &amp; Security Interest','AWS Certified Cloud Practitioner, building foundational knowledge in cloud infrastructure.');
INSERT INTO about_features VALUES (3,'fa-plane-departure','Next Chapter','Relocating to Vancouver, Canada (March 2026)');

-- certificates
CREATE TABLE certificates (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  type TEXT NOT NULL,
  title TEXT NOT NULL,
  issuer TEXT,
  date TEXT,
  icon_type TEXT,
  credential_url TEXT,
  issuing_org TEXT,
  is_expired INTEGER
);
INSERT INTO certificates VALUES (1,'IT','AWS Certified Cloud Practitioner','Amazon Web Services','2024-01','fa-cloud',NULL,'AWS',0);
