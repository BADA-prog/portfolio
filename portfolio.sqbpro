INSERT INTO certificates VALUES (5,'Language','English Language Proficiency','Official Authority','2024-01','fa-globe',NULL,'Language Institute',0);

-- core_strenghts
CREATE TABLE core_strenghts (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  strength_name TEXT,
  icon_class TEXT,
  display_order INTEGER
);
INSERT INTO core_strenghts VALUES (1,'Creative Thinker','fas fa-lightbulb',1);
INSERT INTO core_strenghts VALUES (2,'High Responsibility','fas fa-check-circle',2);
INSERT INTO core_strenghts VALUES (3,'Problem Solver','fas fa-puzzle-piece',3);
INSERT INTO core_strenghts VALUES (4,'Fast Learner','fas fa-bolt',4);

-- coursework
CREATE TABLE coursework (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  subject_name TEXT NOT NULL,
  grade TEXT NOT NULL,
  category TEXT,
  display_order INTEGER DEFAULT 0
);
INSERT INTO coursework VALUES (1,'Database Management','A','Major',1);
INSERT INTO coursework VALUES (2,'System Analysis and Design','A','Major',2);
INSERT INTO coursework VALUES (3,'Software Project Management','A+','Major',3);
INSERT INTO coursework VALUES (4,'R Programming','A+','Elective',4);
INSERT INTO coursework VALUES (5,'Web Design for Financial Statement','A','Elective',5);

-- experience
CREATE TABLE experience (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  category TEXT,
  organization TEXT,
  role TEXT,
  start_year TEXT,
  start_month TEXT,
  is_present INTEGER,
  description TEXT,
  location TEXT,
  city TEXT
);
INSERT INTO experience VALUES (1,'WORK','Career Transition &amp; Relocation','Pre-landing Preparation','2026','02',1,'Intensive full-stack development upskilling (Python, Flask, MySQL) and strategic relocation preparation for Vancouver, Canada.','Taiwan','Taoyuan');
